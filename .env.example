# ═══════════════════════════════════════════
# XBot Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════

# ─── REQUIRED: Telegram Bot ───
TELEGRAM_TOKEN=your_telegram_bot_token_from_botfather
BOT_OWNER_ID=your_telegram_username

# ─── AI Providers (at least one required) ───
# Get 
# Get GEMINI_API_KEY= https://aistudio.google.com/
# Get GROQ_API_KEY= https://console.groq.com/keys
# Get OPENAI_API_KEY= https://platform.openai.com/login

GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key

# ─── OKX OnchainOS (required for DeFi features) ───
# Get keys at: https://web3.okx.com/onchainos/dev-portal
OKX_API_KEY=your_okx_api_key
OKX_SECRET_KEY=your_okx_secret_key
OKX_API_PASSPHRASE=your_okx_passphrase

# ─── Security (REQUIRED for wallet encryption) ───
# Must be exactly 32 random characters of your choice
WALLET_ENCRYPT_SECRET=your_32_chr_random_secret_str_here

# ─── Optional Settings ───
# Daily limit for server API key usage per user (when user has no personal API key set via /api or /ai).
AI_SERVER_KEY_DAILY_LIMIT=50
RPC_URL=wss://xlayerws.okx.com
