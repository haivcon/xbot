# ═══════════════════════════════════════════
# XBot Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════

# ─── REQUIRED: Telegram Bot ───
# Get your token from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_from_botfather
BOT_USERNAME=your_bot_username   # without @
# Your Telegram user ID (numeric, e.g. 123456789 or haivcon)
BOT_OWNER_ID=your_telegram_user_id
PUBLIC_BASE_URL=https://yourdomain.com
# Comma-separated owner IDs if multiple admins (optional)
# OWNER_IDS=123456789,987654321

# ─── AI Providers (at least one required) ───
# Gemini: https://aistudio.google.com/
# Groq:   https://console.groq.com/keys
# OpenAI: https://platform.openai.com/login
# You can use multiple keys separated by commas for automatic rotation
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key

# ─── OKX OnchainOS (required for DeFi: swap, balance, gas) ───
# Get keys at: https://web3.okx.com/onchainos/dev-portal
OKX_API_KEY=your_okx_api_key
OKX_SECRET_KEY=your_okx_secret_key
OKX_API_PASSPHRASE=your_okx_passphrase
# OKX_API_PROJECT=your_okx_project_id     # Optional: OKX project ID
# OKX_BASE_URL=https://www.okx.com        # Optional: OKX base URL

# ─── Security (REQUIRED for wallet encryption) ───
# AES-256 encryption key — must be exactly 32 random characters
# ⚠️ DO NOT CHANGE after wallets are created, or access will be lost
WALLET_ENCRYPT_SECRET=your_32_chr_random_secret_str_here
# Owner password for admin commands (optional)
# OWNER_PASSWORD=your_admin_password

# ─── Web Dashboard ───
# Public URL for dashboard auto-login links (REQUIRED on VPS)
# PUBLIC_BASE_URL=https://yourdomain.com
# JWT secret for dashboard auth (auto-generated from TELEGRAM_TOKEN if not set)
# DASHBOARD_JWT_SECRET=your_random_secret_here
# Set to 'true' to disable dev login buttons in production
# DASHBOARD_DISABLE_DEV_LOGIN=true

# ─── AI Configuration ───
# Daily server API key usage limit per user (when no personal key set via /api)
AI_SERVER_KEY_DAILY_LIMIT=50
# Default language: en | vi | zh | ko | ru | id
# DEFAULT_LANG=vi

# ─── AI Models (optional overrides) ───
# Gemini
# GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp
# Groq
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=llama-3.2-90b-vision-preview
# GROQ_API_URL=https://api.groq.com/openai/v1
# OpenAI
# OPENAI_MODEL=gpt-4o
# OPENAI_VISION_MODEL=gpt-4o
# OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy
# OPENAI_TRANSCRIBE_MODEL=whisper-1

# ─── AI TTS (Text-to-Speech) ───
# Gemini TTS settings
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_VOICE=Kore
# GEMINI_TTS_SAMPLE_RATE=24000
# GEMINI_TTS_CHANNELS=1
# GEMINI_TTS_BIT_DEPTH=16

# ─── Blockchain ───
# RPC URL for X Layer
# XLAYER_RPC_URL=https://rpc.xlayer.tech
# WebSocket URLs (comma-separated for failover)
# XLAYER_WS_URLS=wss://xlayerws.okx.com
# Legacy alias
RPC_URL=wss://xlayerws.okx.com

# ─── Token & Wallet Config ───
# Contract address (BanMao token on X Layer)
# CONTRACT_ADDRESS=0x...
# OKX_BANMAO_TOKEN_ADDRESS=0x...
# OKX_QUOTE_TOKEN_ADDRESS=0x...
# Community wallet for rewards
# COMMUNITY_WALLET_ADDRESS=0x...
# Bot reward private key (for auto-distribution)
# BOT_REWARD_PRIVATE_KEY=your_private_key

# ─── Price Alerts ───
# PRICE_ALERT_POLL_INTERVAL_MS=60000     # Poll every 60s
# PRICE_ALERT_DEFAULT_INTERVAL=300000    # Default 5min interval
# PRICE_ALERT_MAX_PER_TICK=5             # Max alerts per tick
# PRICE_ALERT_RATE_LIMIT_MS=10000        # Min time between alerts

# ─── API Server ───
# Internal API server port (default: 3000)
# API_PORT=3000
# Rate limiting: max requests within a time window
# API_RATE_LIMIT_MAX=120
# API_RATE_LIMIT_WINDOW_MS=60000
# Request timeout in ms
# API_REQUEST_TIMEOUT_MS=10000
# Max pending requests before 503
# API_MAX_PENDING_REQUESTS=300
# Max JSON body size
# API_BODY_LIMIT=64kb
# Enable Prometheus-style metrics endpoint
# API_METRICS_ENABLED=true

# ─── Job Queue (optional: Redis for multi-instance) ───
# JOB_QUEUE_REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://localhost:6379
# JOB_QUEUE_NAME=xbot-jobs
# JOB_QUEUE_CONCURRENCY=3
# JOB_QUEUE_ATTEMPTS=3
# JOB_QUEUE_BACKOFF_MS=5000

# ─── Logging ───
# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info
# Log format: text | json (default: text, use json for monitoring tools)
# LOG_FORMAT=text

# ─── Advanced (rarely need to change) ───
# NODE_ENV=production
# TELEGRAM_MESSAGE_SAFE_LENGTH=4096
# AI_IMAGE_MAX_BYTES=20971520
# AI_IMAGE_DOWNLOAD_TIMEOUT_MS=30000
# AI_KEY_PROBE_TIMEOUT_MS=5000
# TOKEN_PRICE_CACHE_TTL=60000
# START_VIDEO_FILE_ID=                   # Telegram file ID for /start video
# CHECKIN_SCIENCE_PROBABILITY=0.3        # Probability of science fact on check-in
