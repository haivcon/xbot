# ═══════════════════════════════════════════
# XBot Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════

# ─── REQUIRED: Telegram Bot ───
# Get your token from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_from_botfather
BOT_USERNAME=your_bot_username   # without @
# Your Telegram user ID (numeric, e.g. 123456789 or haivcon)
BOT_OWNER_ID=your_telegram_user_id
PUBLIC_BASE_URL=https://yourdomain.com
# Comma-separated owner IDs if multiple admins (optional)
# OWNER_IDS=123456789,987654321

# ─── AI Providers (at least one required) ───
# Gemini: https://aistudio.google.com/
# Groq:   https://console.groq.com/keys
# OpenAI: https://platform.openai.com/login
# You can use multiple keys separated by commas for automatic rotation
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key

# ─── OKX OnchainOS (required for DeFi: swap, balance, gas) ───
# Get keys at: https://web3.okx.com/onchainos/dev-portal
OKX_API_KEY=your_okx_api_key
OKX_SECRET_KEY=your_okx_secret_key
OKX_API_PASSPHRASE=your_okx_passphrase
# OKX_API_PROJECT=your_okx_project_id     # Optional: OKX project ID
# OKX_BASE_URL=https://www.okx.com        # Optional: OKX base URL

# ─── Security (REQUIRED for wallet encryption) ───
# AES-256 encryption key — must be exactly 32 random characters
# ⚠️ DO NOT CHANGE after wallets are created, or access will be lost
WALLET_ENCRYPT_SECRET=your_32_chr_random_secret_str_here
# Owner password for admin commands (optional)
# OWNER_PASSWORD=your_admin_password

# ─── Web Dashboard ───
# Public URL for dashboard auto-login links (REQUIRED on VPS)
# PUBLIC_BASE_URL=https://yourdomain.com
# JWT secret for dashboard auth (auto-generated from TELEGRAM_TOKEN if not set)
# DASHBOARD_JWT_SECRET=your_random_secret_here
# Set to 'true' to disable dev login buttons in production
# DASHBOARD_DISABLE_DEV_LOGIN=true

# ─── AI Configuration ───
# Daily server API key usage limit per user (when no personal key set via /api)
AI_SERVER_KEY_DAILY_LIMIT=50
# Default language: en | vi | zh | ko | ru | id
# DEFAULT_LANG=vi

# ─── AI Models (optional overrides) ───
# Gemini
# GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp
# Groq
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=llama-3.2-90b-vision-preview
# GROQ_API_URL=https://api.groq.com/openai/v1
# OpenAI
# OPENAI_MODEL=gpt-4o
# OPENAI_VISION_MODEL=gpt-4o
# OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy
# OPENAI_TRANSCRIBE_MODEL=whisper-1

# ─── AI TTS (Text-to-Speech) ───
# Gemini TTS settings
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_VOICE=Kore
# GEMINI_TTS_SAMPLE_RATE=24000
# GEMINI_TTS_CHANNELS=1
# GEMINI_TTS_BIT_DEPTH=16

# ─── Blockchain ───
# RPC URL for X Layer
# XLAYER_RPC_URL=https://rpc.xlayer.tech
# WebSocket URLs (comma-separated for failover)
# XLAYER_WS_URLS=wss://xlayerws.okx.com
# Legacy alias
RPC_URL=wss://xlayerws.okx.com

# ─── Token & Wallet Config ───
# Contract address (BanMao token on X Layer)
# CONTRACT_ADDRESS=0x...
# OKX_BANMAO_TOKEN_ADDRESS=0x...
# OKX_QUOTE_TOKEN_ADDRESS=0x...
# Community wallet for rewards
# COMMUNITY_WALLET_ADDRESS=0x...
# Bot reward private key (for auto-distribution)
# BOT_REWARD_PRIVATE_KEY=your_private_key

# ─── Price Alerts ───
# PRICE_ALERT_POLL_INTERVAL_MS=60000     # Poll every 60s
# PRICE_ALERT_DEFAULT_INTERVAL=300000    # Default 5min interval
# PRICE_ALERT_MAX_PER_TICK=5             # Max alerts per tick
# PRICE_ALERT_RATE_LIMIT_MS=10000        # Min time between alerts

# ─── API Server ───
# Internal API server port (default: 3000)
# API_PORT=3000
# Rate limiting: max requests within a time window
# API_RATE_LIMIT_MAX=120
# API_RATE_LIMIT_WINDOW_MS=60000
# Request timeout in ms
# API_REQUEST_TIMEOUT_MS=10000
# Max pending requests before 503
# API_MAX_PENDING_REQUESTS=300
# Max JSON body size
# API_BODY_LIMIT=64kb
# Enable Prometheus-style metrics endpoint
# API_METRICS_ENABLED=true

# ─── Job Queue (optional: Redis for multi-instance) ───
# JOB_QUEUE_REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://localhost:6379
# JOB_QUEUE_NAME=xbot-jobs
# JOB_QUEUE_CONCURRENCY=3
# JOB_QUEUE_ATTEMPTS=3
# JOB_QUEUE_BACKOFF_MS=5000

# ─── Logging ───
# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info
# Log format: text | json (default: text, use json for monitoring tools)
# LOG_FORMAT=text

# ─── Advanced (rarely need to change) ───
# NODE_ENV=production
# TELEGRAM_MESSAGE_SAFE_LENGTH=4096
# AI_IMAGE_MAX_BYTES=20971520
# AI_IMAGE_DOWNLOAD_TIMEOUT_MS=30000
# AI_KEY_PROBE_TIMEOUT_MS=5000
# TOKEN_PRICE_CACHE_TTL=60000
# START_VIDEO_FILE_ID=                   # Telegram file ID for /start video
# CHECKIN_SCIENCE_PROBABILITY=0.3        # Probability of science fact on check-in

# ─── Social Trading Hub (optional) ───
# Set to 'true' to disable the social hub features (feed, DMs, tips)
# DISABLE_SOCIAL_HUB=false
# Max post content length (default: 2000 characters)
# SOCIAL_POST_MAX_LENGTH=2000
# Min seconds between tips to same user (default: 30)
# SOCIAL_TIP_COOLDOWN_SECONDS=30
# DM polling interval in ms for frontend auto-refresh (default: 8000)
# SOCIAL_DM_POLL_INTERVAL_MS=8000
# Leaderboard maximum entries (default: 20)
# SOCIAL_LEADERBOARD_LIMIT=20

# ═══════════════════════════════════════════
# Multi-Channel Expansion (Idea #3)
# Inspired by OpenClaw's multi-platform architecture
# Each channel is optional — enable by installing its SDK + setting env vars
# ═══════════════════════════════════════════

# ─── Discord Channel ───
# Create a bot at: https://discord.com/developers/applications
# Required permission: Send Messages, Read Message History, Use Slash Commands
# DISCORD_TOKEN=your_discord_bot_token
# DISCORD_CLIENT_ID=your_discord_client_id

# ─── Slack Channel ───
# Create a Slack app at: https://api.slack.com/apps
# Enable Socket Mode for real-time events without a public URL
# Required scopes: chat:write, channels:read, channels:history, im:history
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_SIGNING_SECRET=your_slack_signing_secret
# SLACK_APP_TOKEN=xapp-your-slack-app-token   # Required for Socket Mode

# ─── WhatsApp Channel ───
# Uses whatsapp-web.js (mirrors real WhatsApp Web session)
# First run will show QR code in terminal — scan with your phone
# After first login, session is saved locally and auto-reconnects
# No env vars required — just install: npm install whatsapp-web.js
# Optional: npm install qrcode-terminal   (to display QR in terminal)

# ─── Signal Channel ───
# Requires signal-cli REST API running as a Docker container
# Setup guide: https://github.com/bbernhard/signal-cli-rest-api
# docker run -d -p 8080:8080 bbernhard/signal-cli-rest-api
# Then register/link your phone number via the API
# SIGNAL_API_URL=http://localhost:8080
# SIGNAL_PHONE_NUMBER=+1234567890

# ─── LINE Channel ───
# Create a LINE Messaging API channel at: https://developers.line.biz/
# Set webhook URL to: https://yourdomain.com/line/webhook
# LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
# LINE_CHANNEL_SECRET=your_line_channel_secret
# LINE_WEBHOOK_PORT=3100   # Local port for LINE webhook server

# ─── MS Teams Channel ───
# Register a bot in Azure Bot Framework: https://dev.botframework.com/
# Set messaging endpoint to: https://yourdomain.com/api/messages
# TEAMS_APP_ID=your_azure_bot_app_id
# TEAMS_APP_PASSWORD=your_azure_bot_app_password
# TEAMS_WEBHOOK_PORT=3978   # Local port for Teams webhook server

# ─── Web Chat Channel (WebSocket) ───
# Built-in WebSocket server for custom web UIs and dashboards
# Auth token prevents unauthorized connections (required in production)
# WEB_CHANNEL_AUTH_TOKEN=your_random_secret_token
# WEB_CHANNEL_PORT=8080   # WebSocket server port

# ═══════════════════════════════════════════
# AI Auto Trading Agent (Idea #1)
# ═══════════════════════════════════════════
# Auto trading uses existing OKX OnchainOS keys (configured above)
# Signal polling interval in ms (default: 90000 = 90 seconds)
# AUTO_TRADING_POLL_INTERVAL_MS=90000
# Max research calls per user per minute (default: 3)
# AUTO_TRADING_MAX_RESEARCH_PER_MIN=3
# Research cache TTL in ms (default: 300000 = 5 minutes)
# AUTO_TRADING_CACHE_TTL_MS=300000

# ═══════════════════════════════════════════
# x402 Micropayment Gateway (Idea #2)
# ═══════════════════════════════════════════
# x402 API for pay-per-use premium features on X Layer
# Docs: https://x402-xlayer.okx.com/docs
# X402_API_URL=https://x402-xlayer.okx.com
# Your wallet address to receive payments (must be 0x... 42 chars)
# X402_RECIPIENT_ADDRESS=0xYourWalletAddressHere
