# ═══════════════════════════════════════════
# Dashboard Customization
# Copy to .env and edit values
# All vars must start with VITE_ to be available in the browser
# ═══════════════════════════════════════════

# ─── Branding ───
# VITE_APP_NAME=XBot
# VITE_APP_TAGLINE=Dashboard
# VITE_APP_DESCRIPTION=Manage your bot with a powerful web interface
# VITE_APP_VERSION=1.0
# VITE_FOOTER_TEXT=Powered by Telegram

# ─── Blockchain Explorer ───
# VITE_EXPLORER_URL=https://www.okx.com/web3/explorer/xlayer
# VITE_CHAIN_NAME=X Layer

# ─── API ───
# VITE_API_BASE=/api/dashboard
# VITE_WS_URL=ws://localhost:3001/ws

# ─── Language ───
# VITE_DEFAULT_LANG=en

# ─── Dev ───
# VITE_DEV_LOGIN=true
